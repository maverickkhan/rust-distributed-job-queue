# Copy to `.env` and adjust. NEVER commit a real .env.

# --- Database (required) ---
# Connection string used by both the API and the workers.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/djq
DB_MAX_CONNECTIONS=10

# --- API server ---
API_BIND_ADDR=0.0.0.0:8080
API_MAX_BODY_BYTES=1048576

# --- Worker ---
# Comma-separated list of queues this worker pulls from.
WORKER_QUEUES=default,emails
WORKER_CONCURRENCY=8
WORKER_LEASE_SECS=30
WORKER_POLL_MS=500
WORKER_HEARTBEAT_SECS=10
WORKER_SHUTDOWN_GRACE_SECS=30
WORKER_METRICS_ADDR=0.0.0.0:9091

# --- Observability ---
# Standard tracing filter, e.g. info, debug, djq_worker=debug,sqlx=warn
RUST_LOG=info,sqlx=warn,hyper=warn
# Set to "true" for JSON structured logs (recommended in production).
LOG_JSON=false
